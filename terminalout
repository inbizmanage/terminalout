def find_ttyd():
    ttyd_path = shutil.which('ttyd')
    if ttyd_path:
        return ttyd_path
    
    home_ttyd = os.path.expanduser('~/.local/bin/ttyd')
    if os.path.exists(home_ttyd) and os.access(home_ttyd, os.X_OK):
        return home_ttyd
        
    return None

def find_cloudflared():
    cf_path = shutil.which('cloudflared')
    if cf_path:
        return cf_path
    
    home_cf = os.path.expanduser('~/.local/bin/cloudflared')
    if os.path.exists(home_cf) and os.access(home_cf, os.X_OK):
        return home_cf
        
    return None

def start_cloudflare_tunnel(port, ssl_enabled):
    cf_path = find_cloudflared()
    if not cf_path:
        return None, None
    
    cf_log_dir = os.path.expanduser('~/.terminalout')
    os.makedirs(cf_log_dir, exist_ok=True)
    cf_log_path = os.path.join(cf_log_dir, 'cloudflared.log')
    if os.path.exists(cf_log_path):
        try:
            os.remove(cf_log_path)
        except Exception:
            pass
            
    try:
        cf_log_file = open(cf_log_path, 'w')
        cf_url_target = f"https://127.0.0.1:{port}" if ssl_enabled else f"http://127.0.0.1:{port}"
        cf_cmd = [cf_path, "tunnel", "--url", cf_url_target]
        if ssl_enabled:
            cf_cmd.append("--no-tls-verify")
        
        cf_process = subprocess.Popen(
            cf_cmd,
            stdout=cf_log_file,
            stderr=cf_log_file,
            stdin=subprocess.DEVNULL,
            start_new_session=True
        )
        
        # Esperar a la URL
        cf_url = None
        for _ in range(30): # hasta 15 segundos
            time.sleep(0.5)
            if os.path.exists(cf_log_path):
                with open(cf_log_path, 'r') as f:
                    content = f.read()
                    import re
                    match = re.search(r'https://[a-zA-Z0-9-]+\.trycloudflare\.com', content)
                    if match:
                        cf_url = match.group(0)
                        break
            if cf_process.poll() is not None:
                break
                
        return cf_process, cf_url
    except Exception as e:
        print(f"No se pudo iniciar Cloudflare Tunnel: {e}")
        return None, None

def find_free_port(start_port=7681):
    port = start_port
    while port < 65535:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind(('0.0.0.0', port))
                return port
            except socket.error:
                port += 1
    return None

def get_local_ips():
    ips = ['127.0.0.1']
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(('8.8.8.8', 80))
        main_ip = s.getsockname()[0]
        if main_ip not in ips:
            ips.append(main_ip)
        s.close()
    except Exception:
        pass
    return ips

def generate_password(length=8):
    alphabet = string.ascii_lowercase + string.digits
    return ''.join(secrets.choice(alphabet) for _ in range(length))

def ensure_ssl_certs():
    ssl_dir = os.path.expanduser('~/.terminalout/ssl')
    os.makedirs(ssl_dir, exist_ok=True)
    cert_path = os.path.join(ssl_dir, 'cert.pem')
    key_path = os.path.join(ssl_dir, 'key.pem')
    
    if not os.path.exists(cert_path) or not os.path.exists(key_path):
        print(f"{C_YELLOW}Generando certificado SSL autofirmado para HTTPS local...{C_RESET}")
        cmd = [
            'openssl', 'req', '-newkey', 'rsa:2048', '-nodes', 
            '-keyout', key_path, '-x509', '-days', '365', 
            '-out', cert_path, '-subj', '/CN=localhost'
        ]
        try:
            subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
            print(f"{C_GREEN}Certificado SSL generado con éxito en {ssl_dir}{C_RESET}")
        except subprocess.CalledProcessError as e:
            print(f"{C_RED}Error al generar el certificado SSL con openssl: {e}{C_RESET}")
            sys.exit(1)
            
    return cert_path, key_path

def make_qr_lines(data, invert=True):
    """Genera una lista de líneas de texto QR en ASCII."""
    try:
        import qrcode as _qrcode
        import io
        qr = _qrcode.QRCode(
            version=None,
            error_correction=_qrcode.constants.ERROR_CORRECT_L,
            box_size=1,
            border=1
        )
        qr.add_data(data)
        qr.make(fit=True)
        buf = io.StringIO()
        qr.print_ascii(out=buf, invert=invert)
        lines = buf.getvalue().splitlines()
        return lines
    except Exception:
        return ['[QR no disponible]']

def print_qr_side_by_side(lines_left, lines_right, label_left, label_right):
    """Imprime dos QR codes uno al lado del otro con etiquetas."""
    # Normalizar longitudes
    max_l = max(len(l) for l in lines_left)  if lines_left  else 0
    max_r = max(len(l) for l in lines_right) if lines_right else 0
    max_rows = max(len(lines_left), len(lines_right))
    
    gap = '   '
    
    # Encabezados centrados
    left_header  = label_left.center(max_l)
    right_header = label_right.center(max_r)
    print(f"  {C_CYAN}{C_BOLD}{left_header}{C_RESET}{gap}{C_MAGENTA}{C_BOLD}{right_header}{C_RESET}")
    print(f"  {'─' * max_l}{gap}{'─' * max_r}")
    
    for i in range(max_rows):
        l = lines_left[i]  if i < len(lines_left)  else ' ' * max_l
        r = lines_right[i] if i < len(lines_right) else ' ' * max_r
        # Padding a la derecha para alinear
        l = l + ' ' * (max_l - len(l))
        r = r + ' ' * (max_r - len(r))
        print(f"  {l}{gap}{r}")
    print()

