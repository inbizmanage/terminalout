def stop_daemon():
    pid_file = os.path.expanduser('~/.terminalout/terminalout.pid')
    session_file = os.path.expanduser('~/.terminalout/session.json')
    
    if not os.path.exists(pid_file):
        print(f"{C_YELLOW}No hay ningún servidor terminalout activo registrado en segundo plano.{C_RESET}")
        return
        
    try:
        with open(pid_file, 'r') as f:
            pids_str = f.read().strip()
        pids = [int(p) for p in pids_str.split(',') if p]
    except Exception:
        pids = []
        
    if pids:
        print(f"Deteniendo procesos de terminalout (PIDs: {pids_str})...")
        for pid in pids:
            try:
                import signal
                os.kill(pid, signal.SIGTERM)
                print(f" - Proceso {pid} detenido.")
            except ProcessLookupError:
                print(f" - Proceso {pid} ya no estaba en ejecución.")
            except PermissionError:
                print(f"{C_RED} - Sin permisos suficientes para detener el proceso {pid}.{C_RESET}")
            except Exception as e:
                print(f"{C_RED} - Error al detener el proceso {pid}: {e}{C_RESET}")
        print(f"{C_GREEN}Servidor detenido y limpio.{C_RESET}")
            
    # Limpiar archivos de estado
    if os.path.exists(pid_file):
        os.remove(pid_file)
    if os.path.exists(session_file):
        os.remove(session_file)

def print_status():
    session_file = os.path.expanduser('~/.terminalout/session.json')
    pid_file = os.path.expanduser('~/.terminalout/terminalout.pid')
    
    if not os.path.exists(session_file) or not os.path.exists(pid_file):
        print(f"{C_YELLOW}No hay ningún servidor terminalout en segundo plano en ejecución.{C_RESET}")
        return
        
    try:
        with open(session_file, 'r') as f:
            session = json.load(f)
        
        # Verificar si los PIDs siguen vivos
        pids = session.get('pids', [])
        alive = True
        for pid in pids:
            try:
                os.kill(pid, 0)
            except OSError:
                alive = False
                break
                
        if not alive:
            print(f"{C_RED}El servidor en segundo plano está incompleto o inactivo. Limpiando residuos...{C_RESET}")
            stop_daemon()
            return
            
        # Leer secreto TOTP del config
        totp_secret = '???'
        try:
            cfg_path = os.path.expanduser('~/.terminalout/config.json')
            with open(cfg_path) as _f:
                totp_secret = json.load(_f).get('totp_secret', '???')
        except Exception:
            pass

        print_banner(
            port=session['port'],
            ips=session['ips'],
            totp_secret=totp_secret,
            theme_name=session['theme'],
            read_only=session['read_only'],
            ssl_enabled=session['ssl_enabled'],
            is_background=True,
            pid=pids[1],
            cf_url=session.get('cf_url')
        )
    except Exception as e:
        print(f"{C_RED}Error al leer el estado del servidor: {e}{C_RESET}")

def main():
    parser = argparse.ArgumentParser(description="terminalout: Servidor web de terminal con soporte HTTPS, segundo plano y optimización móvil PWA.")
    
    parser.add_argument("action", nargs="?", choices=["start", "stop", "status"], default=None, 
                        help="Acción a realizar: 'start' (segundo plano), 'stop' (detener), 'status' (ver estado)")
    
    parser.add_argument("-b", "--background", action="store_true", help="Ejecutar el servidor en segundo plano (equivalente a 'start')")
    parser.add_argument("-p", "--port", type=int, default=None, help="Puerto del servidor (por defecto busca a partir de 7681)")
    parser.add_argument("-i", "--interface", type=str, default="0.0.0.0", help="Interfaz de red a enlazar (por defecto: 0.0.0.0)")
    parser.add_argument("-r", "--read-only", action="store_true", help="Hacer la terminal de solo lectura")
    parser.add_argument("-u", "--username", type=str, default="admin", help="Nombre de usuario para basic auth")
    parser.add_argument("-P", "--password", type=str, default=None, help="Contraseña para basic auth (por defecto se genera aleatoria)")
    parser.add_argument("-n", "--no-auth", action="store_true", help="Desactivar autenticación (¡Peligro!)")
    parser.add_argument("-t", "--theme", type=str, choices=list(THEMES.keys()), default="slate", help="Tema visual")
    parser.add_argument("-c", "--command", type=str, default=None, help="Comando a ejecutar (por defecto la shell actual o bash)")
    parser.add_argument("--http", action="store_true", help="Usar HTTP en lugar de HTTPS")
    
    args = parser.parse_args()
    
    if args.action == 'stop':
        stop_daemon()
        sys.exit(0)
    elif args.action == 'status':
        print_status()
        sys.exit(0)
    elif args.action == 'start':
        args.background = True

    # 1. Verificar binario ttyd y proxy js
    ttyd_path = find_ttyd()
    if not ttyd_path:
        print(f"{C_RED}{C_BOLD}Error: No se pudo encontrar el binario de 'ttyd'.{C_RESET}")
        sys.exit(1)
        
    proxy_script = os.path.expanduser('~/.terminalout/server.js')
    if not os.path.exists(proxy_script):
        print(f"{C_RED}{C_BOLD}Error: No se pudo encontrar el script proxy en '{proxy_script}'.{C_RESET}")
        sys.exit(1)
        
    # 2. Configurar puertos
    port = args.port
    if port is None:
        port = find_free_port(7681)
        if port is None:
            print(f"{C_RED}{C_BOLD}Error: No se pudo encontrar ningún puerto libre para el proxy.{C_RESET}")
            sys.exit(1)
            
    ttyd_port = find_free_port(port + 1)
    if ttyd_port is None:
        print(f"{C_RED}{C_BOLD}Error: No se pudo encontrar ningún puerto libre para ttyd.{C_RESET}")
        sys.exit(1)
            
    # 3. Configurar comando
    cmd = args.command
    if not cmd:
        cmd = os.environ.get('SHELL', 'bash')
        
    # 4. Cargar o crear configuración TOTP
    config_path = os.path.expanduser('~/.terminalout/config.json')
    os.makedirs(os.path.expanduser('~/.terminalout'), exist_ok=True)
    try:
        with open(config_path) as _f:
            _cfg = json.load(_f)
    except Exception:
        _cfg = {}

    if 'totp_secret' not in _cfg:
        # Generar secreto TOTP con Python
        import base64
        totp_secret = base64.b32encode(os.urandom(20)).decode('utf-8').rstrip('=')
        _cfg['totp_secret'] = totp_secret
        with open(config_path, 'w') as _f:
            json.dump(_cfg, _f)
        print(f"\n{C_GREEN}{C_BOLD}✓ Secreto TOTP generado por primera vez.{C_RESET}")
        print(f"  Abre la URL del servidor en tu navegador para escanear el QR con Google Authenticator.\n")
    
    # 5. Obtener IPs locales
    ips = get_local_ips()
    
    # 6. Configurar SSL / HTTPS
    ssl_enabled = not args.http
    cert_path, key_path = None, None
    if ssl_enabled:
        cert_path, key_path = ensure_ssl_certs()
        
    # 7. Preparar argumentos de ttyd (se enlaza SOLAMENTE en localhost, sin auth ya que la maneja el proxy)
    ttyd_args = [ttyd_path, "-p", str(ttyd_port), "-i", "127.0.0.1"]
    if not args.read_only:
        ttyd_args.append("-W")
        
    # Pasar el tema visual a ttyd
    theme_data = THEMES[args.theme]
    client_options = {
        "theme": theme_data,
        "fontSize": 15,
        "fontFamily": "JetBrains Mono, Fira Code, Cascadia Code, Courier New, monospace",
        "cursorBlink": True,
        "macOptionIsMeta": True
    }
    for key, val in client_options.items():
        if isinstance(val, dict):
            val_str = json.dumps(val, separators=(',', ':'))
            ttyd_args.extend(["-t", f"{key}={val_str}"])
        else:
            val_str = str(val).lower() if isinstance(val, bool) else str(val)
            ttyd_args.extend(["-t", f"{key}={val_str}"])
    ttyd_args.append(cmd)
    
    # 8. Preparar argumentos de proxy Node.js
    config_path = os.path.expanduser('~/.terminalout/config.json')
    proxy_args = [
        "node", proxy_script,
        f"--port={port}",
        f"--ttyd-port={ttyd_port}",
        f"--ssl={'true' if ssl_enabled else 'false'}",
        f"--theme={args.theme}",
        f"--config={config_path}"
    ]
    if ssl_enabled:
        proxy_args.extend([
            f"--cert={cert_path}",
            f"--key={key_path}"
        ])
        
    # 9. Ejecución
    if args.background:
        pid_file = os.path.expanduser('~/.terminalout/terminalout.pid')
        if os.path.exists(pid_file):
            try:
                with open(pid_file, 'r') as f:
                    pids_str = f.read().strip()
                pids = [int(p) for p in pids_str.split(',') if p]
                for p in pids:
                    os.kill(p, 0)
                print(f"{C_RED}Error: Ya hay una instancia de terminalout activa en segundo plano (PIDs: {pids_str}).{C_RESET}")
                print(f"Detén la sesión previa con {C_BOLD}terminalout stop{C_RESET} antes de abrir una nueva.")
                sys.exit(1)
            except (OSError, ValueError):
                pass

        os.makedirs(os.path.expanduser('~/.terminalout'), exist_ok=True)
        log_path = os.path.expanduser('~/.terminalout/terminalout.log')
        log_file = open(log_path, 'a')
        
        try:
            # Arrancar ttyd
            ttyd_process = subprocess.Popen(
                ttyd_args, 
                stdout=log_file, 
                stderr=log_file, 
                stdin=subprocess.DEVNULL,
                start_new_session=True
            )
            
            time.sleep(0.5)
            if ttyd_process.poll() is not None:
                print(f"{C_RED}Error: El servidor ttyd no pudo mantenerse en ejecución.{C_RESET}")
                print(f"Revisa el log en: {log_path}")
                sys.exit(1)
                
            # Arrancar Proxy Node.js
            proxy_process = subprocess.Popen(
                proxy_args, 
                stdout=log_file, 
                stderr=log_file, 
                stdin=subprocess.DEVNULL,
                start_new_session=True
            )
            
            time.sleep(0.5)
            if proxy_process.poll() is not None:
                ttyd_process.terminate()
                ttyd_process.wait()
                print(f"{C_RED}Error: El servidor proxy no pudo mantenerse en ejecución.{C_RESET}")
                print(f"Revisa el log en: {log_path}")
                sys.exit(1)
                
            # Arrancar túnel de Cloudflare si está disponible
            cf_process, cf_url = start_cloudflare_tunnel(port, ssl_enabled)
            
            pids = [ttyd_process.pid, proxy_process.pid]
            if cf_process:
                pids.append(cf_process.pid)
            
            # Guardar PIDs
            pids_str = ",".join(str(p) for p in pids)
            with open(pid_file, 'w') as f:
                f.write(pids_str)
                
            session_data = {
                "pids": pids,
                "port": port,
                "ips": ips,
                "no_auth": False,
                "theme": args.theme,
                "read_only": args.read_only,
                "ssl_enabled": ssl_enabled,
                "cf_url": cf_url
            }
            session_file = os.path.expanduser('~/.terminalout/session.json')
            with open(session_file, 'w') as f:
                json.dump(session_data, f)

            # Leer el secreto TOTP del config
            totp_secret = cfg.get('totp_secret', '???') if 'cfg' in dir() else '???'
            try:
                import json as _json
                with open(config_path) as _f:
                    totp_secret = _json.load(_f).get('totp_secret', '???')
            except Exception:
                pass

            print_banner(port, ips, totp_secret, args.theme, args.read_only, ssl_enabled, is_background=True, pid=proxy_process.pid, cf_url=cf_url)
            
            if ssl_enabled:
                print(f"{C_YELLOW}⚠️  NOTA DE SEGURIDAD:{C_RESET}")
                print(f" Al acceder vía HTTPS con certificado autofirmado local, tu navegador dirá 'La conexión no es privada'.")
                print(f" Para proceder, haz clic en '{C_BOLD}Configuración avanzada{C_RESET}' y selecciona '{C_BOLD}Acceder a... (no seguro){C_RESET}'.\n")
                
        except Exception as e:
            print(f"{C_RED}Error al iniciar el servidor en segundo plano: {e}{C_RESET}")
            sys.exit(1)
            
    else:
        # Ejecución estándar en primer plano
        totp_secret = '???'
        try:
            import json as _j
            with open(config_path) as _f:
                totp_secret = _j.load(_f).get('totp_secret', '???')
        except Exception:
            pass

        ttyd_process = None
        proxy_process = None
        cf_process = None
        cf_url = None
        try:
            # 1. Arrancar ttyd
            ttyd_process = subprocess.Popen(
                ttyd_args,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
            time.sleep(0.5)
            if ttyd_process.poll() is not None:
                print(f"{C_RED}Error: El servidor ttyd no pudo iniciarse.{C_RESET}")
                sys.exit(1)
                
            # 2. Arrancar Proxy
            proxy_process = subprocess.Popen(proxy_args)
            time.sleep(0.5)
            if proxy_process.poll() is not None:
                print(f"{C_RED}Error: El servidor proxy no pudo iniciarse.{C_RESET}")
                sys.exit(1)

            # 3. Arrancar Túnel de Cloudflare
            cf_process, cf_url = start_cloudflare_tunnel(port, ssl_enabled)
            
            # 4. Imprimir Banner ahora que tenemos toda la info
            print_banner(port, ips, totp_secret, args.theme, args.read_only, ssl_enabled, is_background=False, cf_url=cf_url)
            
            if ssl_enabled:
                print(f"{C_YELLOW}⚠️  NOTA DE SEGURIDAD:{C_RESET}")
                print(f" Al acceder vía HTTPS con certificado autofirmado local, tu navegador dirá 'La conexión no es privada'.")
                print(f" Para proceder, haz clic en '{C_BOLD}Configuración avanzada{C_RESET}' y selecciona '{C_BOLD}Acceder a... (no seguro){C_RESET}'.\n")

            while True:
                time.sleep(1)
                if ttyd_process.poll() is not None or proxy_process.poll() is not None:
                    break
                if cf_process and cf_process.poll() is not None:
                    print(f"{C_RED}El túnel de Cloudflare se ha cerrado inesperadamente.{C_RESET}")
                    break
        except KeyboardInterrupt:
            print(f"\n{C_YELLOW}Deteniendo servidores...{C_RESET}")
        finally:
            if ttyd_process:
                ttyd_process.terminate()
                ttyd_process.wait()
            if proxy_process:
                proxy_process.terminate()
                proxy_process.wait()
            if cf_process:
                cf_process.terminate()
                cf_process.wait()
            print(f"{C_GREEN}Servidores detenidos correctamente. ¡Hasta luego!{C_RESET}")

if __name__ == '__main__':
    main()
